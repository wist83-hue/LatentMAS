{
  "model": {
    "base_model": "Qwen/Qwen3-0.6B",
    "teacher_model": "Qwen/Qwen3-0.6B",
    "is_do_alignment": false,
    "alignment_strategy": "first",
    "projector": {
      "type": "C2CProjector",
      "params": {
        "hidden_dim": 1024,
        "intermediate_dim": 1024,
        "num_layers": 3,
        "dropout": 0.1,
        "initial_temperature": 1.0,
        "final_temperature": 0.001,
        "anneal_steps": 150
      }
    },
    "mapping": "last_aligned"
  },
  "training": {
    "learning_rate": 0.0001,
    "weight_decay": 0.01,
    "num_epochs": 1,
    "max_length": 1024,
    "device": "cuda",
    "scheduler_type": "linear",
    "warmup_ratio": 0.1,
    "max_grad_norm": 1.0,
    "gradient_accumulation_steps": 128,
    "per_device_train_batch_size": 2,
    "num_processes": 1,
    "freeze": [
      "teacher",
      "base"
    ],
    "seed": 42
  },
  "output": {
    "output_dir": "local/checkpoints/identical_0.6+0.6",
    "save_steps": 50,
    "eval_steps": 50,
    "wandb_config": {
      "project": "Rosetta",
      "mode": "offline",
      "entity": "local",
      "run_name": "identical_0.6+0.6"
    }
  },
  "data": {
    "type": "OpenHermesChatDataset",
    "kwargs": {
      "split": "train",
      "max_word_count": 1024,
      "num_samples": 50000
    },
    "train_ratio": 0.99
  }
}